# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Auth — change this in production. Must be at least 16 chars.
API_TOKEN=dev-token-please-change-me-1234567890

# CORS: "*" or comma-separated list of origins
CORS_ORIGIN=*

# Logging: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Seed data on boot (no-op if DB already has rows)
SEED_DATA=true

# Persistence: "sqlite" (default) or "memory"
DATABASE_DRIVER=sqlite

# SQLite location. Use "file:./data/roles.db" for disk or ":memory:" for ephemeral.
# Railway: point this at a persistent volume, e.g. file:/data/roles.db
DATABASE_URL=file:./data/roles.db
